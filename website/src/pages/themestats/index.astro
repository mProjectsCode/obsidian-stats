---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import DataIndex from '../../components/svelte/DataIndex.svelte';
import { ItemType } from '../../utils/misc';
---

<StarlightPage
	frontmatter={{
		title: 'Theme Overview',
		description: `Overview of all Obsidian themes.`,
		head: [
			{
				tag: 'style',
				content: ':root { --sl-content-width: 90rem !important; }',
			},
		],
		tableOfContents: false,
	}}
>
	<p>
		This table lists all themes ever available in the community theme gallery. You can search for all fields at once, or use targeted filters like
		<code>name:</code>, <code>author:</code>, <code>repo:</code>, and <code>id:</code>.
	</p>

	<DataIndex dataUrl="/obsidian-stats/data/themes/overview.json" type={ItemType.Theme} client:only="svelte" />
</StarlightPage>
